{
  "name": "solslot-portal",
  "version": "0.0.0",
  "description": "Solslot operator portal for signed-artifact administration, deterministic genesis, trust-root reads, and audited protocol actions",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev:stack": "node scripts/dev-stack.mjs",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "postinstall": "node scripts/copy-chia-wasm.mjs",
    "copy-chia-wasm": "node scripts/copy-chia-wasm.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~20.3.26",
    "@angular/common": "~20.3.26",
    "@angular/compiler": "~20.3.26",
    "@angular/core": "~20.3.26",
    "@angular/forms": "~20.3.26",
    "@angular/platform-browser": "~20.3.26",
    "@angular/router": "~20.3.26",
    "@walletconnect/ethereum-provider": "~2.23.10",
    "@walletconnect/sign-client": "~2.23.10",
    "@zkpassport/sdk": "~0.15.7",
    "@zkpassport/ui": "~0.15.10",
    "@zkpassport/utils": "~0.37.3",
    "chia-bls": "^1.0.3",
    "chia-wallet-sdk": "^0.33.0",
    "chia-wallet-sdk-wasm": "file:src/assets/chia_wasm",
    "clvm-lib": "^1.0.1",
    "ethers": "~6.17.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "~20.3.32",
    "@angular/cli": "~20.3.32",
    "@angular/compiler-cli": "~20.3.26",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.20",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "~8.5.17",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "ethers": "$ethers"
  }
}
